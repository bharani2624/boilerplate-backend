# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=local

# Supabase Postgres connection string (Session Pooler, port 6543, for serverless-friendly pooling)
DATABASE_URL=postgresql://postgres.xxxxxxxx:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5

# Auth — generate JWT_SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINUTES=43200

# Google OAuth — Web application OAuth client ID from Google Cloud Console
GOOGLE_CLIENT_ID=
